<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.RegisterPage"
             Title="Register">

    <ScrollView>
        <VerticalStackLayout Padding="30,30,30,60" Spacing="12" VerticalOptions="Center">

            <Label Text="Create an account"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <Label Text="Name" FontAttributes="Bold" />
            <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Full name" />
            <Label Text="{Binding NameError}" IsVisible="{Binding HasNameError}" TextColor="Red" FontSize="12" />

            <Label Text="Email" FontAttributes="Bold" />
            <Entry Text="{Binding Email, Mode=TwoWay}" Placeholder="you@email.com" Keyboard="Email" />
            <Label Text="{Binding EmailError}" IsVisible="{Binding HasEmailError}" TextColor="Red" FontSize="12" />

            <Label Text="Password" FontAttributes="Bold" />
            <Entry Text="{Binding Password, Mode=TwoWay}" IsPassword="True" Placeholder="Password" />
            <Label Text="{Binding PasswordError}" IsVisible="{Binding HasPasswordError}" TextColor="Red" FontSize="12" />

            <Label Text="{Binding ApiError}" IsVisible="{Binding HasApiError}" TextColor="Red" FontSize="13" Margin="0,8,0,0" />
            <Label Text="{Binding SuccessMessage}" IsVisible="{Binding HasSuccessMessage}" TextColor="Green" FontSize="13" Margin="0,8,0,0" />

            <Button Text="Register"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsFormValid}"
                    Margin="0,16,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
