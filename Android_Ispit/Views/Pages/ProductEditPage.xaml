<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.ProductEditPage"
             Title="Product">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,60" Spacing="10">

            <Label Text="Title" FontAttributes="Bold" />
            <Entry Text="{Binding Title, Mode=TwoWay}" Placeholder="Product title" />
            <Label Text="{Binding TitleError}" IsVisible="{Binding HasTitleError}" TextColor="Red" FontSize="12" />

            <Label Text="Price" FontAttributes="Bold" />
            <Entry Text="{Binding PriceText, Mode=TwoWay}" Placeholder="0.00" Keyboard="Numeric" />
            <Label Text="{Binding PriceError}" IsVisible="{Binding HasPriceError}" TextColor="Red" FontSize="12" />

            <Label Text="Category" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />
            <Label Text="{Binding CategoryError}" IsVisible="{Binding HasCategoryError}" TextColor="Red" FontSize="12" />

            <Label Text="Description" FontAttributes="Bold" />
            <Editor Text="{Binding Description, Mode=TwoWay}" HeightRequest="100" AutoSize="TextChanges" />
            <Label Text="{Binding DescriptionError}" IsVisible="{Binding HasDescriptionError}" TextColor="Red" FontSize="12" />

            <Label Text="Images (one URL per line)" FontAttributes="Bold" />
            <Editor Text="{Binding ImagesText, Mode=TwoWay}" HeightRequest="90" AutoSize="TextChanges" />
            <Label Text="{Binding ImagesError}" IsVisible="{Binding HasImagesError}" TextColor="Red" FontSize="12" />

            <Label Text="{Binding ApiError}" IsVisible="{Binding HasApiError}" TextColor="Red" Margin="0,8,0,0" />

            <Button Text="Save"
                    Clicked="OnSaveClicked"
                    IsEnabled="{Binding IsFormValid}"
                    Margin="0,16,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
