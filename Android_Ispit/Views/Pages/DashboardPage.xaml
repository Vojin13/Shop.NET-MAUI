<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.DashboardPage"
             Title="Products">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadProductsCommand}">
        <ScrollView x:Name="ContentScrollView">
            <VerticalStackLayout Padding="16,16,16,60" Spacing="10">

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Image Grid.Column="0"
                           Source="linea_icon.png"
                           WidthRequest="28"
                           HeightRequest="28"
                           Aspect="AspectFit" />
                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                        <Label Text="Products" FontFamily="SpaceGrotesk" FontSize="28" FontAttributes="Bold" />
                        <Label Text="{Binding ItemCountText}" FontSize="13" TextColor="{StaticResource InkMuted}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2"
                           Text="Log out"
                           TextColor="{StaticResource Primary}"
                           FontSize="14"
                           VerticalOptions="Start">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Button Text="+ Add Product"
                        FontFamily="SpaceGrotesk"
                        FontAttributes="Bold"
                        Clicked="OnAddClicked"
                        Margin="0,6,0,0" />

                <SearchBar Placeholder="Search"
                           Text="{Binding SearchText, Mode=TwoWay}"
                           SearchButtonPressed="OnSearchButtonPressed" />

                <Picker x:Name="CategoryPicker"
                        ItemsSource="{Binding Categories}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                        SelectedIndexChanged="OnCategoryChanged" />

                <Label Text="{Binding ApiError}"
                       IsVisible="{Binding HasApiError}"
                       TextColor="{StaticResource ErrorColor}"
                       Margin="0,0,0,10" />

                <Label Text="No products found."
                       IsVisible="{Binding HasNoResults}"
                       TextColor="{StaticResource InkMuted}"
                       HorizontalOptions="Center"
                       Margin="0,20,0,0" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Products}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="14">
                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="12">
                                        <Image Grid.Column="0"
                                               Source="{Binding MainImage}"
                                               Aspect="AspectFill"
                                               HeightRequest="60"
                                               WidthRequest="60" />
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                            <Label Text="{Binding Title}"
                                                   FontFamily="SpaceGrotesk"
                                                   FontAttributes="Bold"
                                                   FontSize="15"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding CategoryName}" FontSize="12" TextColor="{StaticResource InkMuted}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2"
                                               Text="{Binding PriceDisplay}"
                                               FontFamily="SpaceGrotesk"
                                               FontAttributes="Bold"
                                               FontSize="15"
                                               TextColor="{StaticResource Ink}"
                                               VerticalOptions="Center" />
                                    </Grid>

                                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource AccentSoft}" />

                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                        <Button Text="Edit"
                                                FontSize="12"
                                                Padding="14,6"
                                                BackgroundColor="{StaticResource SurfaceInput}"
                                                TextColor="{StaticResource Ink}"
                                                Clicked="OnEditClicked" />
                                        <Button Text="Delete"
                                                FontSize="12"
                                                Padding="14,6"
                                                BackgroundColor="{StaticResource ErrorColor}"
                                                Clicked="OnDeleteClicked" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0">
                    <Button Grid.Column="0"
                            Text="Previous"
                            Clicked="OnPreviousClicked"
                            IsEnabled="{Binding CanGoPrevious}"
                            FontSize="13"
                            Padding="12,6" />
                    <Label Grid.Column="1"
                           Text="{Binding CurrentPageNumber, StringFormat='Page {0}'}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Button Grid.Column="2"
                            Text="Next"
                            Clicked="OnNextClicked"
                            IsEnabled="{Binding CanGoNext}"
                            FontSize="13"
                            Padding="12,6" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
