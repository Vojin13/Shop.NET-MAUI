<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Android_Ispit.Behaviors"
             x:Class="Android_Ispit.Views.Pages.UserEditPage"
             Title="User">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,60" Spacing="10">

            <Label Text="Name" FontAttributes="Bold" />
            <Border Stroke="{StaticResource AccentSoft}" StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="0">
                <Border.Behaviors>
                    <behaviors:FocusBorderBehavior />
                </Border.Behaviors>
                <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Full name" />
            </Border>
            <Label Text="{Binding NameError}" IsVisible="{Binding HasNameError}" TextColor="{StaticResource ErrorColor}" FontSize="12" />

            <Label Text="Email" FontAttributes="Bold" />
            <Border Stroke="{StaticResource AccentSoft}" StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="0">
                <Border.Behaviors>
                    <behaviors:FocusBorderBehavior />
                </Border.Behaviors>
                <Entry Text="{Binding Email, Mode=TwoWay}" Placeholder="user@email.com" Keyboard="Email" />
            </Border>
            <Label Text="{Binding EmailError}" IsVisible="{Binding HasEmailError}" TextColor="{StaticResource ErrorColor}" FontSize="12" />

            <Label Text="Password" FontAttributes="Bold" />
            <Border Stroke="{StaticResource AccentSoft}" StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="0">
                <Border.Behaviors>
                    <behaviors:FocusBorderBehavior />
                </Border.Behaviors>
                <Entry Text="{Binding Password, Mode=TwoWay}"
                       IsPassword="True"
                       Placeholder="{Binding PasswordPlaceholder}" />
            </Border>
            <Label Text="{Binding PasswordError}" IsVisible="{Binding HasPasswordError}" TextColor="{StaticResource ErrorColor}" FontSize="12" />

            <Label Text="Role" FontAttributes="Bold" />
            <Border Stroke="{StaticResource AccentSoft}" StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="0">
                <Border.Behaviors>
                    <behaviors:FocusBorderBehavior />
                </Border.Behaviors>
                <Picker ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole, Mode=TwoWay}" />
            </Border>
            <Label Text="{Binding RoleError}" IsVisible="{Binding HasRoleError}" TextColor="{StaticResource ErrorColor}" FontSize="12" />

            <Label Text="{Binding ApiError}" IsVisible="{Binding HasApiError}" TextColor="{StaticResource ErrorColor}" Margin="0,8,0,0" />

            <Button Text="Save"
                    FontFamily="SpaceGrotesk"
                    FontAttributes="Bold"
                    Clicked="OnSaveClicked"
                    IsEnabled="{Binding IsFormValid}"
                    Margin="0,16,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
