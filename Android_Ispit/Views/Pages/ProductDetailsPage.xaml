<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.ProductDetailsPage"
             Title="Product Details">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,60" Spacing="10">

            <Image Source="{Binding Product.MainImage}"
                   Aspect="AspectFill"
                   HeightRequest="240"
                   HorizontalOptions="Fill" />

            <Label Text="{Binding Product.Title}" FontSize="22" FontAttributes="Bold" />
            <Label Text="{Binding Product.CategoryName}" FontSize="13" TextColor="Gray" />
            <Label Text="{Binding Product.PriceDisplay}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Primary}" />

            <Label Text="Description" FontAttributes="Bold" Margin="0,10,0,0" />
            <Label Text="{Binding Product.Description}" />

            <Label Text="Quantity" FontAttributes="Bold" Margin="0,10,0,0" />
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="-"
                        Command="{Binding DecrementQuantityCommand}"
                        IsEnabled="{Binding CanDecrementQuantity}"
                        WidthRequest="48" />
                <Label Grid.Column="1"
                       Text="{Binding Quantity}"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="+"
                        Command="{Binding IncrementQuantityCommand}"
                        IsEnabled="{Binding CanIncrementQuantity}"
                        WidthRequest="48" />
            </Grid>

            <Button Text="Add to Cart"
                    Command="{Binding AddToCartCommand}"
                    Margin="0,16,0,0" />
            <Label Text="{Binding CartMessage}"
                   IsVisible="{Binding HasCartMessage}"
                   TextColor="Green"
                   HorizontalOptions="Center" />

            <Label Text="Related Products"
                   FontAttributes="Bold"
                   FontSize="16"
                   Margin="0,20,0,0"
                   IsVisible="{Binding HasRelatedProducts}" />

            <CollectionView ItemsSource="{Binding RelatedProducts}"
                             IsVisible="{Binding HasRelatedProducts}"
                             HeightRequest="140">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="8" WidthRequest="120" CornerRadius="10" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRelatedProductTapped" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Image Source="{Binding MainImage}" Aspect="AspectFill" HeightRequest="70" />
                                <Label Text="{Binding Title}" FontSize="12" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding PriceDisplay}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
