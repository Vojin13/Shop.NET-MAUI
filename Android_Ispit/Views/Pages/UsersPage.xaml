<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.UsersPage"
             Title="Users">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadUsersCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,60" Spacing="10">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Manage Users"
                           FontSize="24"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Logout"
                            Clicked="OnLogoutClicked"
                            FontSize="13"
                            Padding="12,6" />
                </Grid>

                <Button Text="+ Add User"
                        Clicked="OnAddClicked"
                        Margin="0,4,0,0" />

                <Label Text="{Binding ApiError}"
                       IsVisible="{Binding HasApiError}"
                       TextColor="Red"
                       Margin="0,0,0,10" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Users}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" CornerRadius="12" HasShadow="True">
                                <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="10">
                                    <Image Grid.Column="0"
                                           Source="{Binding Avatar}"
                                           Aspect="AspectFill"
                                           HeightRequest="60"
                                           WidthRequest="60" />
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="15"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Email}" FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding Role}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="6">
                                        <Button Text="Edit" FontSize="12" Padding="8,4" Clicked="OnEditClicked" />
                                        <Button Text="Delete" FontSize="12" Padding="8,4" BackgroundColor="IndianRed" Clicked="OnDeleteClicked" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
