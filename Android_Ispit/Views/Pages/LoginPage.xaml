<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.LoginPage"
             Title="Login">

    <ScrollView>
        <VerticalStackLayout Padding="30,30,30,60" Spacing="12" VerticalOptions="Center">

            <Label Text="Welcome back"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <Label Text="Email" FontAttributes="Bold" />
            <Entry Text="{Binding Email, Mode=TwoWay}"
                   Placeholder="you@email.com"
                   Keyboard="Email" />
            <Label Text="{Binding EmailError}"
                   IsVisible="{Binding HasEmailError}"
                   TextColor="Red"
                   FontSize="12" />

            <Label Text="Password" FontAttributes="Bold" />
            <Entry Text="{Binding Password, Mode=TwoWay}"
                   IsPassword="True"
                   Placeholder="Password" />
            <Label Text="{Binding PasswordError}"
                   IsVisible="{Binding HasPasswordError}"
                   TextColor="Red"
                   FontSize="12" />

            <Label Text="{Binding ApiError}"
                   IsVisible="{Binding HasApiError}"
                   TextColor="Red"
                   FontSize="13"
                   Margin="0,8,0,0" />

            <Button Text="Log In"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsFormValid}"
                    Margin="0,16,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                HorizontalOptions="Center" />

            <Label Text="Test accounts: john@mail.com / changeme (customer), admin@mail.com / admin123 (admin)"
                   FontSize="11"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
