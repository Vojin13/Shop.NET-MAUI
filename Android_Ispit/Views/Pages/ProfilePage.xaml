<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             Title="My Profile">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,16,16,4">
            <Frame Grid.Column="0"
                   WidthRequest="40"
                   HeightRequest="40"
                   Padding="0"
                   CornerRadius="12"
                   BackgroundColor="{StaticResource SurfaceCard}"
                   BorderColor="Transparent"
                   HorizontalOptions="Start">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Frame.GestureRecognizers>
                <Label Text="&#8249;"
                       FontSize="22"
                       TextColor="{StaticResource Ink}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>
            <Label Grid.Column="1"
                   Text="My Profile"
                   FontFamily="SpaceGrotesk"
                   FontAttributes="Bold"
                   FontSize="16"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,10,24,30" Spacing="16" HorizontalOptions="Center">

                <Frame WidthRequest="120"
                       HeightRequest="120"
                       CornerRadius="60"
                       Padding="0"
                       IsClippedToBounds="True"
                       BorderColor="Transparent"
                       HorizontalOptions="Center"
                       Margin="0,10,0,0">
                    <Image Source="{Binding Avatar}" Aspect="AspectFill" />
                </Frame>

                <Frame BackgroundColor="{StaticResource SurfaceCard}" BorderColor="Transparent" Padding="16,12" HorizontalOptions="Fill">
                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Email" FontSize="12" TextColor="{StaticResource InkMuted}" />
                            <Label Text="{Binding Email}" FontAttributes="Bold" FontSize="15" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource AccentSoft}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Role" FontSize="12" TextColor="{StaticResource InkMuted}" />
                            <Frame Padding="10,4"
                                   CornerRadius="12"
                                   BackgroundColor="{StaticResource AccentSoft}"
                                   BorderColor="Transparent"
                                   HorizontalOptions="Start">
                                <Label Text="{Binding Role}" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="12" />
                            </Frame>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource AccentSoft}" />

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Member since" FontSize="12" TextColor="{StaticResource InkMuted}" />
                            <Label Text="{Binding CreatedDisplay}" FontAttributes="Bold" FontSize="15" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
