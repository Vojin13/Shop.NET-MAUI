<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.CartPage"
             x:Name="RootPage"
             Title="Cart">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,60" Spacing="10">

            <HorizontalStackLayout Spacing="10">
                <Image Source="linea_icon.png" WidthRequest="28" HeightRequest="28" Aspect="AspectFit" />
                <Label Text="Cart" FontFamily="SpaceGrotesk" FontSize="28" FontAttributes="Bold" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Label Text="{Binding ItemCountText}"
                   FontSize="13"
                   TextColor="{StaticResource InkMuted}"
                   IsVisible="{Binding HasItems}"
                   Margin="0,0,0,6" />

            <Frame IsVisible="{Binding HasPurchaseMessage}"
                   BackgroundColor="{StaticResource SuccessSurface}"
                   BorderColor="Transparent"
                   Padding="14,10"
                   Margin="0,10,0,0">
                <HorizontalStackLayout Spacing="10">
                    <Frame WidthRequest="8" HeightRequest="8" Padding="0" CornerRadius="4"
                           BackgroundColor="{StaticResource SuccessColor}" BorderColor="Transparent"
                           VerticalOptions="Center" />
                    <Label Text="{Binding PurchaseMessage}" TextColor="{StaticResource SuccessColor}" FontSize="14" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Frame>

            <Label Text="Your cart is empty."
                   IsVisible="{Binding ShowEmptyMessage}"
                   TextColor="{StaticResource InkMuted}"
                   HorizontalOptions="Center"
                   Margin="0,40,0,0" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}" Spacing="10" IsVisible="{Binding HasItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12">
                            <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">
                                <Image Grid.Column="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="64"
                                       WidthRequest="64" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Title}"
                                           FontFamily="SpaceGrotesk"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding PriceDisplay}" FontSize="12" TextColor="{StaticResource InkMuted}" />
                                    <Label Text="{Binding LineTotalDisplay}"
                                           FontFamily="SpaceGrotesk"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           TextColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="6" HorizontalOptions="End">
                                    <Frame Padding="2" CornerRadius="16" BackgroundColor="{StaticResource SurfaceInput}" BorderColor="Transparent">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="2">
                                            <Button Grid.Column="0"
                                                    Text="-"
                                                    Command="{Binding BindingContext.DecrementCommand, Source={x:Reference RootPage}}"
                                                    CommandParameter="{Binding .}"
                                                    WidthRequest="30"
                                                    HeightRequest="30"
                                                    MinimumHeightRequest="0"
                                                    MinimumWidthRequest="0"
                                                    CornerRadius="15"
                                                    Padding="0"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{StaticResource Ink}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Quantity}"
                                                   WidthRequest="22"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalOptions="Center" />
                                            <Button Grid.Column="2"
                                                    Text="+"
                                                    Command="{Binding BindingContext.IncrementCommand, Source={x:Reference RootPage}}"
                                                    CommandParameter="{Binding .}"
                                                    WidthRequest="30"
                                                    HeightRequest="30"
                                                    MinimumHeightRequest="0"
                                                    MinimumWidthRequest="0"
                                                    CornerRadius="15"
                                                    Padding="0"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{StaticResource Ink}" />
                                        </Grid>
                                    </Frame>
                                    <Label Text="Remove"
                                           FontSize="11"
                                           TextColor="{StaticResource ErrorColor}"
                                           HorizontalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.RemoveCommand, Source={x:Reference RootPage}}"
                                                                   CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Frame IsVisible="{Binding HasItems}"
                   BackgroundColor="{StaticResource SurfaceCard}"
                   BorderColor="Transparent"
                   Padding="16,14"
                   Margin="0,10,0,0">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Total" FontFamily="SpaceGrotesk" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding TotalDisplay}" FontFamily="SpaceGrotesk" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </Grid>
                    <Button Text="Checkout" FontFamily="SpaceGrotesk" FontAttributes="Bold" Command="{Binding CheckoutCommand}" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
