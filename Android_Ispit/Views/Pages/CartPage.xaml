<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Android_Ispit.Views.Pages.CartPage"
             x:Name="RootPage"
             Title="Cart">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,60" Spacing="10">

            <Label Text="Cart" FontSize="24" FontAttributes="Bold" />

            <Label Text="Your cart is empty."
                   IsVisible="{Binding ShowEmptyMessage}"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0" />

            <Label Text="{Binding PurchaseMessage}"
                   IsVisible="{Binding HasPurchaseMessage}"
                   TextColor="Green"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}" Spacing="10" IsVisible="{Binding HasItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10" CornerRadius="12" HasShadow="True">
                            <Grid ColumnDefinitions="70,*,Auto" ColumnSpacing="10">
                                <Image Grid.Column="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="70"
                                       WidthRequest="70" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding PriceDisplay}" FontSize="12" TextColor="Gray" />
                                    <Label Text="{Binding LineTotalDisplay}"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="6">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="4">
                                        <Button Grid.Column="0"
                                                Text="-"
                                                Command="{Binding BindingContext.DecrementCommand, Source={x:Reference RootPage}}"
                                                CommandParameter="{Binding .}"
                                                WidthRequest="36"
                                                Padding="0" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Quantity}"
                                               WidthRequest="26"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center" />
                                        <Button Grid.Column="2"
                                                Text="+"
                                                Command="{Binding BindingContext.IncrementCommand, Source={x:Reference RootPage}}"
                                                CommandParameter="{Binding .}"
                                                WidthRequest="36"
                                                Padding="0" />
                                    </Grid>
                                    <Button Text="Remove"
                                            FontSize="11"
                                            Padding="4,2"
                                            TextColor="Red"
                                            BackgroundColor="Transparent"
                                            Command="{Binding BindingContext.RemoveCommand, Source={x:Reference RootPage}}"
                                            CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="LightGray" Margin="0,10,0,0" IsVisible="{Binding HasItems}" />

            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasItems}" Margin="0,10,0,0">
                <Label Grid.Column="0" Text="Total" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="{Binding TotalDisplay}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
            </Grid>

            <Button Text="Checkout"
                    Command="{Binding CheckoutCommand}"
                    IsVisible="{Binding HasItems}"
                    Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
