<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Android_Ispit.Behaviors"
             x:Class="Android_Ispit.Views.Pages.CategoryEditPage"
             Title="Category">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,60" Spacing="10">

            <Label Text="Name" FontAttributes="Bold" />
            <Border Stroke="{StaticResource AccentSoft}" StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="0">
                <Border.Behaviors>
                    <behaviors:FocusBorderBehavior />
                </Border.Behaviors>
                <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Category name" />
            </Border>
            <Label Text="{Binding NameError}" IsVisible="{Binding HasNameError}" TextColor="{StaticResource ErrorColor}" FontSize="12" />

            <Label Text="Image URL" FontAttributes="Bold" />
            <Border Stroke="{StaticResource AccentSoft}" StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="0">
                <Border.Behaviors>
                    <behaviors:FocusBorderBehavior />
                </Border.Behaviors>
                <Entry Text="{Binding ImageUrl, Mode=TwoWay}" Placeholder="https://..." />
            </Border>
            <Label Text="{Binding ImageUrlError}" IsVisible="{Binding HasImageUrlError}" TextColor="{StaticResource ErrorColor}" FontSize="12" />

            <Label Text="{Binding ApiError}" IsVisible="{Binding HasApiError}" TextColor="{StaticResource ErrorColor}" Margin="0,8,0,0" />

            <Button Text="Save"
                    FontFamily="SpaceGrotesk"
                    FontAttributes="Bold"
                    Clicked="OnSaveClicked"
                    IsEnabled="{Binding IsFormValid}"
                    Margin="0,16,0,0" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
